PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://user:password@localhost:5432/skenee
# Access token — short lived
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m
# Refresh token — long lived, stored server-side
# Generate with: openssl rand -hex 32
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
REFRESH_TOKEN_EXPIRES_IN=30d

# Matrix/Synapse — must match registration_shared_secret in synapse/data/homeserver.yaml
# Generate with: openssl rand -hex 32
MATRIX_HOMESERVER_URL=https://matrix.yourdomain.com
MATRIX_SHARED_SECRET=your-secret-here
MATRIX_DOMAIN=matrix.yourdomain.com

# Synapse admin access token for token refresh (Synapse >= 1.64.0)
# Create an admin user in Synapse, log in via Matrix client API, and use
# the returned access_token here. Required for regenerateMatrixToken().
# Without this, Matrix token expiry cannot be recovered.
MATRIX_ADMIN_TOKEN=

# Redis — required for job queue (Phase 2) and caching (Phase 3)
# Local: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK — required for push notifications
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Then extract these three fields from the JSON file
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="your-private-key-with-literal-newlines"

# Email — required for password reset
# Gmail: use App Password (not your main password)
# Other: any SMTP provider works
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@skene.app
# Used to build the reset link in emails
FRONTEND_URL=http://localhost:5173
